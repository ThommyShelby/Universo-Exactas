{
  "expo": {
    "name": "Universo Exactas",
    "slug": "universo-exactas",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#050519"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#050519",
        "foregroundImage": "./assets/icon.png"
      },
      "package": "com.universo.exactas"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser",
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "5b338f65-5040-4263-897a-14b4c2762bc7"
      }
    }
  }
}