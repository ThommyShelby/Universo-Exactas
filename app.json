{
  "expo": {
    "name": "Universo Exactas",
    "slug": "universo-exactas",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#050519"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#050519",
        "foregroundImage": "./assets/icon.png"
      },
      "package": "com.universo.exactas",
      "permissions": [
        "NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#818CF8",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "495857ff-1781-4553-8e9b-83ca11977058"
      }
    }
  }
}
